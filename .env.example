# Copia este archivo como .env y ajusta los valores
# Copy this file as .env and adjust the values

# Contraseña por defecto para el primer torneo (cámbiala después de crear el torneo)
DEFAULT_ADMIN_PASSWORD=admin123

# Backup de la base de datos (opcional — para persistencia entre deploys)
# En Streamlit Cloud añade estas variables en Settings → Secrets
#
# Opción A: Cloudflare R2 (recomendado — gratuito permanente, 10 GB)
#   1. dash.cloudflare.com → R2 → Create bucket
#   2. R2 → Manage R2 API Tokens → Create token (Edit permissions)
#   3. Copia Account ID de la página de R2
# AWS_ACCESS_KEY_ID=<R2 key id>
# AWS_SECRET_ACCESS_KEY=<R2 secret>
# S3_BUCKET=cuadro-tenis
# S3_DB_KEY=tennis/tennis.db
# R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#
# Opción B: AWS S3 (gratis para archivos pequeños)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=
# S3_DB_KEY=tennis/tennis.db
