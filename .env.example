# Copia este archivo como .env y ajusta los valores
# Copy this file as .env and adjust the values

# Contraseña por defecto para el primer torneo (cámbiala después de crear el torneo)
DEFAULT_ADMIN_PASSWORD=admin123

# S3 backup (opcional — para persistencia entre deploys en Streamlit Cloud)
# En Streamlit Cloud añade estas variables en Settings → Secrets
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=
# S3_DB_KEY=tennis/tennis.db
